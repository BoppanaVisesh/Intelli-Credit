# ============================================
# FREE API KEYS (Recommended)
# ============================================

# Google Gemini API - FREE TIER (RECOMMENDED)
# Get from: https://makersuite.google.com/app/apikey
# Free: 1500 requests/day, 60 req/min
# No credit card required!
GEMINI_API_KEY=your_gemini_api_key_here

# Tavily Search API - FREE TIER
# Get from: https://tavily.com
# Free: 1000 searches/month
TAVILY_API_KEY=your_tavily_api_key_here

# Groq API (Optional, for faster inference)
# Get from: https://console.groq.com
# Free tier available
GROQ_API_KEY=your_groq_api_key_here

# ============================================
# PAID API KEYS (Optional)
# ============================================

# OpenAI API (NOT REQUIRED - use Gemini instead)
# Only set this if you want to use OpenAI
OPENAI_API_KEY=

# ============================================
# APPLICATION SETTINGS
# ============================================

# Database
DATABASE_URL=sqlite:///./intellicredit.db

# Application
DEBUG=True

# LLM Provider (gemini/ollama/groq)
LLM_PROVIDER=gemini
